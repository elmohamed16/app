# app.py - تطبيق سوق إلكتروني بتجربة مستخدم غامرة (ملف واحد)
# يتضمن: موجز لا نهائي، تتبع الاهتمامات، FOMO، وضع مظلم

import os
import random
import time
from datetime import datetime, timedelta
from flask import Flask, render_template_string, request, jsonify, session, redirect, url_for
from flask_sqlalchemy import SQLAlchemy
from sqlalchemy import func, desc

# -------------------- إعداد التطبيق --------------------
app = Flask(__name__)
app.secret_key = 'your-secret-key-change-in-production'  # غيّر في الإنتاج
app.config['SQLALCHEMY_DATABASE_URI'] = 'sqlite:///marketplace.db'
app.config['SQLALCHEMY_TRACK_MODIFICATIONS'] = False
db = SQLAlchemy(app)

# -------------------- نماذج قاعدة البيانات --------------------
class User(db.Model):
    id = db.Column(db.Integer, primary_key=True)
    username = db.Column(db.String(80), unique=True, nullable=False)
    password = db.Column(db.String(120), nullable=False)  # في الحقيقة استخدم هاش
    interests = db.Column(db.String(500), default='')     # فاصلة بين الفئات

class Product(db.Model):
    id = db.Column(db.Integer, primary_key=True)
    name = db.Column(db.String(100), nullable=False)
    description = db.Column(db.String(500))
    price = db.Column(db.Float, nullable=False)
    category = db.Column(db.String(50), nullable=False)
    stock = db.Column(db.Integer, default=10)
    views = db.Column(db.Integer, default=0)
    discount_until = db.Column(db.DateTime, nullable=True)  # تاريخ انتهاء الخصم
    discount_price = db.Column(db.Float, nullable=True)
    created_at = db.Column(db.DateTime, default=datetime.utcnow)
    seller_id = db.Column(db.Integer, db.ForeignKey('user.id'))

class Like(db.Model):
    id = db.Column(db.Integer, primary_key=True)
    user_id = db.Column(db.Integer, db.ForeignKey('user.id'))
    product_id = db.Column(db.Integer, db.ForeignKey('product.id'))
    timestamp = db.Column(db.DateTime, default=datetime.utcnow)

# -------------------- دوال مساعدة --------------------
def update_user_interests(user_id, product_category):
    """تحديث قائمة اهتمامات المستخدم عند الإعجاب"""
    user = User.query.get(user_id)
    if user:
        interests = user.interests.split(',') if user.interests else []
        if product_category not in interests:
            interests.append(product_category)
            # الاحتفاظ بآخر 5 اهتمامات فقط لتجنب التضخم
            if len(interests) > 5:
                interests = interests[-5:]
            user.interests = ','.join(interests)
            db.session.commit()

def get_personalized_products(user_id, page=1, per_page=10):
    """جلب منتجات مخصصة بناءً على اهتمامات المستخدم"""
    user = User.query.get(user_id)
    if user and user.interests:
        interest_list = user.interests.split(',')
        # المنتجات التي تطابق أي اهتمام، مع ترتيب عشوائي لتجنب التكرار
        products = Product.query.filter(Product.category.in_(interest_list)) \
                                .order_by(func.random()) \
                                .paginate(page=page, per_page=per_page, error_out=False)
        if products.items:
            return products
    # إذا لم تكن هناك منتجات مخصصة أو نفدت، نعرض أحدث المنتجات
    return Product.query.order_by(desc(Product.created_at)) \
                        .paginate(page=page, per_page=per_page, error_out=False)

def get_product_with_fomo(product):
    """إضافة بيانات FOMO إلى المنتج (مخزون متبقي، نسبة نفاد)"""
    # محاكاة تناقص المخزون بشكل عشوائي لجعله واقعياً
    remaining = max(0, product.stock - random.randint(0, 3))  # محاكاة مشتريات
    return {
        'id': product.id,
        'name': product.name,
        'description': product.description,
        'price': product.price,
        'discount_price': product.discount_price,
        'category': product.category,
        'views': product.views + random.randint(1, 10),  # محاكاة مشاهدات حية
        'stock': remaining,
        'discount_until': product.discount_until.isoformat() if product.discount_until else None,
        'image': f'https://picsum.photos/seed/{product.id}/300/200'  # صور عشوائية
    }

# -------------------- إنشاء الجداول وبيانات اختبار --------------------
with app.app_context():
    db.create_all()
    # إضافة مستخدمين ومنتجات افتراضية إن لم تكن موجودة
    if User.query.count() == 0:
        # مستخدم تجريبي (بائع)
        seller = User(username='seller', password='pass', interests='')
        db.session.add(seller)
        db.session.commit()
        # منتجات تجريبية
        categories = ['إلكترونيات', 'ملابس', 'كتب', 'ألعاب', 'منزل', 'جمال']
        for i in range(50):
            cat = random.choice(categories)
            discount_until = None
            discount_price = None
            if random.random() > 0.7:  # 30% خصم
                discount_until = datetime.utcnow() + timedelta(hours=random.randint(1, 48))
                discount_price = round(random.uniform(5, 50), 2)
            product = Product(
                name=f'منتج {i+1}',
                description=f'وصف رائع للمنتج {i+1} من فئة {cat}',
                price=round(random.uniform(10, 200), 2),
                category=cat,
                stock=random.randint(1, 50),
                views=random.randint(0, 100),
                discount_until=discount_until,
                discount_price=discount_price,
                seller_id=seller.id
            )
            db.session.add(product)
        db.session.commit()

# -------------------- مسارات Flask --------------------
@app.route('/')
def index():
    """الصفحة الرئيسية مع الموجز اللانهائي"""
    if 'user_id' not in session:
        return redirect(url_for('login'))
    user = User.query.get(session['user_id'])
    return render_template_string(HTML_TEMPLATE, user=user)

@app.route('/login', methods=['GET', 'POST'])
def login():
    if request.method == 'POST':
        username = request.form['username']
        password = request.form['password']
        user = User.query.filter_by(username=username, password=password).first()
        if user:
            session['user_id'] = user.id
            return redirect(url_for('index'))
        return "بيانات دخول غير صحيحة", 401
    return render_template_string(LOGIN_TEMPLATE)

@app.route('/register', methods=['GET', 'POST'])
def register():
    if request.method == 'POST':
        username = request.form['username']
        password = request.form['password']
        if User.query.filter_by(username=username).first():
            return "اسم المستخدم موجود مسبقاً", 400
        user = User(username=username, password=password)
        db.session.add(user)
        db.session.commit()
        session['user_id'] = user.id
        return redirect(url_for('index'))
    return render_template_string(REGISTER_TEMPLATE)

@app.route('/logout')
def logout():
    session.pop('user_id', None)
    return redirect(url_for('login'))

# API: جلب المنتجات (للموجز اللانهائي)
@app.route('/api/products')
def api_products():
    page = request.args.get('page', 1, type=int)
    per_page = 12
    user_id = session.get('user_id')
    if not user_id:
        return jsonify([])
    products_page = get_personalized_products(user_id, page, per_page)
    products_data = [get_product_with_fomo(p) for p in products_page.items]
    return jsonify({
        'products': products_data,
        'has_next': products_page.has_next
    })

# API: إعجاب بمنتج
@app.route('/api/like/<int:product_id>', methods=['POST'])
def like_product(product_id):
    user_id = session.get('user_id')
    if not user_id:
        return jsonify({'error': 'غير مسجل'}), 401
    product = Product.query.get(product_id)
    if not product:
        return jsonify({'error': 'منتج غير موجود'}), 404
    # تسجيل الإعجاب (مرة واحدة لكل مستخدم)
    existing = Like.query.filter_by(user_id=user_id, product_id=product_id).first()
    if not existing:
        like = Like(user_id=user_id, product_id=product_id)
        db.session.add(like)
        # تحديث اهتمامات المستخدم بناءً على فئة المنتج
        update_user_interests(user_id, product.category)
        db.session.commit()
    return jsonify({'success': True})

# API: شراء منتج (محاكاة)
@app.route('/api/buy/<int:product_id>', methods=['POST'])
def buy_product(product_id):
    user_id = session.get('user_id')
    if not user_id:
        return jsonify({'error': 'غير مسجل'}), 401
    product = Product.query.get(product_id)
    if not product or product.stock <= 0:
        return jsonify({'error': 'المنتج غير متوفر'}), 400
    # تناقص المخزون (محاكاة)
    product.stock -= 1
    db.session.commit()
    return jsonify({'success': True, 'remaining': product.stock})

