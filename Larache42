    def __init__(self, parent, controller):
        super().__init__(parent)
        self.controller = controller

        label_title = tk.Label(self, text="لوحة تحكم المشتري - تصفح المنتجات", font=("Arial", 20))
        label_title.pack(pady=10)

        # شريط البحث
        frame_search = tk.Frame(self)
        frame_search.pack(pady=5, fill="x")

        tk.Label(frame_search, text="بحث:", font=("Arial", 12)).pack(side="left", padx=5)
        self.entry_search = tk.Entry(frame_search, font=("Arial", 12), width=30)
        self.entry_search.pack(side="left", padx=5)
        btn_search = tk.Button(frame_search, text="بحث", font=("Arial", 12), command=self.search_products)
        btn_search.pack(side="left", padx=5)
        btn_clear = tk.Button(frame_search, text="عرض الكل", font=("Arial", 12), command=self.refresh_products)
        btn_clear.pack(side="left", padx=5)

        # قائمة المنتجات المتاحة
        frame_list = tk.LabelFrame(self, text="المنتجات المتاحة", font=("Arial", 14))
        frame_list.pack(pady=10, padx=20, fill="both", expand=True)

        columns = ("ID", "الاسم", "السعر", "الوصف", "البائع")
        self.tree = ttk.Treeview(frame_list, columns=columns, show="headings")
        for col in columns:
            self.tree.heading(col, text=col)
            self.tree.column(col, width=100)
        self.tree.pack(side="left", fill="both", expand=True)

        scrollbar = ttk.Scrollbar(frame_list, orient="vertical", command=self.tree.yview)
        scrollbar.pack(side="right", fill="y")
        self.tree.configure(yscrollcommand=scrollbar.set)

        # أزرار الإجراءات
        frame_actions = tk.Frame(self)
        frame_actions.pack(pady=10)

        btn_add_cart = tk.Button(frame_actions, text="إضافة إلى السلة", font=("Arial", 12), command=self.add_to_cart)
        btn_add_cart.pack(side="left", padx=10)

        btn_view_cart = tk.Button(frame_actions, text="عرض السلة", font=("Arial", 12), command=self.view_cart)
        btn_view_cart.pack(side="left", padx=10)

        btn_logout = tk.Button(frame_actions, text="تسجيل الخروج", font=("Arial", 12), command=self.controller.logout)
        btn_logout.pack(side="left", padx=10)

    def refresh_products(self):
        """عرض جميع المنتجات"""
        for item in self.tree.get_children():
            self.tree.delete(item)
        products = get_all_products()
        for prod in products:
            self.tree.insert("", "end", values=prod)

    def search_products(self):
        """البحث في المنتجات حسب الاسم أو الوصف"""
        query = self.entry_search.get().strip().lower()
        if not query:
            self.refresh_products()
            return
        for item in self.tree.get_children():
            self.tree.delete(item)
        products = get_all_products()
        for prod in products:
            # prod: (id, name, price, description, seller)
            if query in prod[1].lower() or query in prod[3].lower():
                self.tree.insert("", "end", values=prod)

    def add_to_cart(self):
        """إضافة المنتج المحدد إلى السلة"""
        selected = self.tree.selection()
        if not selected:
            messagebox.showerror("خطأ", "يرجى اختيار منتج")
            return
        item = self.tree.item(selected[0])
        prod_id = item['values'][0]
        # زيادة الكمية في السلة
        if prod_id in self.controller.cart:
            self.controller.cart[prod_id] += 1
        else:
            self.controller.cart[prod_id] = 1
        messagebox.showinfo("نجاح", "تمت إضافة المنتج إلى السلة")

    def view_cart(self):
        """عرض صفحة السلة"""
        self.controller.show_frame("CartPage")
        self.controller.frames["CartPage"].refresh_cart()

