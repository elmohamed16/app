                const discountTimer = hasDiscount ?
                    `<div class="discount-timer" data-until="${p.discount_until}">⏳ ${timeRemaining(p.discount_until)}</div>` :
                    '';
                const stockWarning = p.stock < 5 && p.stock > 0 ?
                    `<div class="stock-warning">⚠️ متبقي ${p.stock} قطع فقط!</div>` :
