# ============================
class LoginPage(tk.Frame):
    def __init__(self, parent, controller):
        super().__init__(parent)
        self.controller = controller

        label_title = tk.Label(self, text="تسجيل الدخول", font=("Arial", 20))
        label_title.pack(pady=30)

        frame_form = tk.Frame(self)
        frame_form.pack(pady=20)

        tk.Label(frame_form, text="اسم المستخدم:", font=("Arial", 12)).grid(row=0, column=0, padx=5, pady=5)
        self.entry_username = tk.Entry(frame_form, font=("Arial", 12))
        self.entry_username.grid(row=0, column=1, padx=5, pady=5)

        tk.Label(frame_form, text="كلمة المرور:", font=("Arial", 12)).grid(row=1, column=0, padx=5, pady=5)
        self.entry_password = tk.Entry(frame_form, show="*", font=("Arial", 12))
        self.entry_password.grid(row=1, column=1, padx=5, pady=5)

        btn_login = tk.Button(self, text="دخول", font=("Arial", 12), command=self.do_login)
        btn_login.pack(pady=10)

        btn_register = tk.Button(self, text="إنشاء حساب جديد", font=("Arial", 12), command=lambda: controller.show_frame("RegisterPage"))
        btn_register.pack(pady=5)

    def do_login(self):
        username = self.entry_username.get().strip()
        password = self.entry_password.get().strip()
        if not username or not password:
            messagebox.showerror("خطأ", "يرجى ملء جميع الحقول")
            return
        if self.controller.login_user(username, password):
            self.entry_username.delete(0, tk.END)
            self.entry_password.delete(0, tk.END)
        else:
            messagebox.showerror("خطأ", "اسم المستخدم أو كلمة المرور غير صحيحة")

