# لوحة تحكم البائع (Seller Dashboard)
# ============================
class SellerDashboard(tk.Frame):
    def __init__(self, parent, controller):
        super().__init__(parent)
        self.controller = controller

        label_title = tk.Label(self, text="لوحة تحكم البائع", font=("Arial", 20))
        label_title.pack(pady=10)

        # قسم إضافة منتج
        frame_add = tk.LabelFrame(self, text="إضافة منتج جديد", font=("Arial", 14))
        frame_add.pack(pady=10, padx=20, fill="x")

        tk.Label(frame_add, text="اسم المنتج:", font=("Arial", 12)).grid(row=0, column=0, padx=5, pady=5, sticky="e")
        self.entry_name = tk.Entry(frame_add, font=("Arial", 12))
        self.entry_name.grid(row=0, column=1, padx=5, pady=5)

        tk.Label(frame_add, text="السعر:", font=("Arial", 12)).grid(row=1, column=0, padx=5, pady=5, sticky="e")
        self.entry_price = tk.Entry(frame_add, font=("Arial", 12))
        self.entry_price.grid(row=1, column=1, padx=5, pady=5)

        tk.Label(frame_add, text="الوصف:", font=("Arial", 12)).grid(row=2, column=0, padx=5, pady=5, sticky="ne")
        self.entry_desc = tk.Text(frame_add, height=3, width=30, font=("Arial", 12))
        self.entry_desc.grid(row=2, column=1, padx=5, pady=5)

        btn_add = tk.Button(frame_add, text="إضافة المنتج", font=("Arial", 12), command=self.add_product)
        btn_add.grid(row=3, column=1, pady=10, sticky="w")

        # قائمة المنتجات المعروضة
        frame_list = tk.LabelFrame(self, text="منتجاتي المعروضة", font=("Arial", 14))
        frame_list.pack(pady=10, padx=20, fill="both", expand=True)

        columns = ("ID", "الاسم", "السعر", "الوصف")
        self.tree = ttk.Treeview(frame_list, columns=columns, show="headings")
        for col in columns:
            self.tree.heading(col, text=col)
            self.tree.column(col, width=100)
        self.tree.pack(side="left", fill="both", expand=True)

        scrollbar = ttk.Scrollbar(frame_list, orient="vertical", command=self.tree.yview)
        scrollbar.pack(side="right", fill="y")
        self.tree.configure(yscrollcommand=scrollbar.set)

        # زر حذف المنتج المحدد
        btn_delete = tk.Button(self, text="حذف المنتج المحدد", font=("Arial", 12), command=self.delete_selected)
        btn_delete.pack(pady=5)

        btn_logout = tk.Button(self, text="تسجيل الخروج", font=("Arial", 12), command=self.controller.logout)
        btn_logout.pack(pady=10)

    def refresh_products(self):
        """تحديث قائمة المنتجات"""
        for item in self.tree.get_children():
            self.tree.delete(item)
        if self.controller.current_user:
            seller_id = self.controller.current_user[0]
            products = get_products_by_seller(seller_id)
            for prod in products:
                self.tree.insert("", "end", values=prod)

    def add_product(self):
        name = self.entry_name.get().strip()
        price_str = self.entry_price.get().strip()
        description = self.entry_desc.get("1.0", tk.END).strip()
        if not name or not price_str:
            messagebox.showerror("خطأ", "يرجى إدخال الاسم والسعر")
            return
        try:
            price = float(price_str)
        except ValueError:
            messagebox.showerror("خطأ", "السعر يجب أن يكون رقماً")
            return
        seller_id = self.controller.current_user[0]
        add_product(seller_id, name, price, description)
        self.entry_name.delete(0, tk.END)
        self.entry_price.delete(0, tk.END)
        self.entry_desc.delete("1.0", tk.END)
        self.refresh_products()
        messagebox.showinfo("نجاح", "تم إضافة المنتج")

    def delete_selected(self):
        selected = self.tree.selection()
        if not selected:
            messagebox.showerror("خطأ", "يرجى اختيار منتج للحذف")
            return
        item = self.tree.item(selected[0])
        prod_id = item['values'][0]
        if messagebox.askyesno("تأكيد", "هل أنت متأكد من حذف هذا المنتج؟"):
            delete_product(prod_id)
            self.refresh_products()

