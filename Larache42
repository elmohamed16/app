import tkinter as tk
from tkinter import ttk, messagebox
import sqlite3
from datetime import datetime

# ============================
# إعداد قاعدة البيانات (Database Setup)
# ============================
def init_db():
    conn = sqlite3.connect('marketplace.db')
    c = conn.cursor()
    c.execute('''CREATE TABLE IF NOT EXISTS users (
                    id INTEGER PRIMARY KEY AUTOINCREMENT,
                    username TEXT UNIQUE NOT NULL,
                    password TEXT NOT NULL,
                    role TEXT NOT NULL
                )''')
    c.execute('''CREATE TABLE IF NOT EXISTS products (
                    id INTEGER PRIMARY KEY AUTOINCREMENT,
                    seller_id INTEGER NOT NULL,
                    name TEXT NOT NULL,
                    price REAL NOT NULL,
                    description TEXT,
                    FOREIGN KEY(seller_id) REFERENCES users(id)
                )''')
    c.execute('''CREATE TABLE IF NOT EXISTS orders (
                    id INTEGER PRIMARY KEY AUTOINCREMENT,
                    buyer_id INTEGER NOT NULL,
                    order_date TEXT NOT NULL,
                    total REAL NOT NULL,
                    status TEXT DEFAULT 'pending',
                    FOREIGN KEY(buyer_id) REFERENCES users(id)
                )''')
    c.execute('''CREATE TABLE IF NOT EXISTS order_items (
                    id INTEGER PRIMARY KEY AUTOINCREMENT,
                    order_id INTEGER NOT NULL,
                    product_id INTEGER NOT NULL,
                    quantity INTEGER NOT NULL,
                    price_at_time REAL NOT NULL,
                    FOREIGN KEY(order_id) REFERENCES orders(id),
                    FOREIGN KEY(product_id) REFERENCES products(id)
                )''')
    conn.commit()
    conn.close()

# ============================
# دوال مساعدة للتعامل مع قاعدة البيانات
# ============================
def get_user(username, password):
    conn = sqlite3.connect('marketplace.db')
    c = conn.cursor()
    c.execute("SELECT id, username, role FROM users WHERE username=? AND password=?", (username, password))
    user = c.fetchone()
    conn.close()
    return user

def register_user(username, password, role):
    conn = sqlite3.connect('marketplace.db')
    c = conn.cursor()
    try:
        c.execute("INSERT INTO users (username, password, role) VALUES (?, ?, ?)", (username, password, role))
        conn.commit()
        success = True
    except sqlite3.IntegrityError:
        success = False
    conn.close()
    return success

def get_products_by_seller(seller_id):
    conn = sqlite3.connect('marketplace.db')
    c = conn.cursor()
    c.execute("SELECT id, name, price, description FROM products WHERE seller_id=?", (seller_id,))
    products = c.fetchall()
    conn.close()
    return products

def add_product(seller_id, name, price, description):
    conn = sqlite3.connect('marketplace.db')
    c = conn.cursor()
    c.execute("INSERT INTO products (seller_id, name, price, description) VALUES (?, ?, ?, ?)",
              (seller_id, name, price, description))
    conn.commit()
    conn.close()

def delete_product(product_id):
    conn = sqlite3.connect('marketplace.db')
    c = conn.cursor()
    c.execute("DELETE FROM products WHERE id=?", (product_id,))
    conn.commit()
    conn.close()

def get_all_products():
    conn = sqlite3.connect('marketplace.db')
    c = conn.cursor()
    c.execute('''SELECT products.id, products.name, products.price, products.description, users.username 
                 FROM products JOIN users ON products.seller_id = users.id''')
    products = c.fetchall()
    conn.close()
    return products

def get_product_by_id(product_id):
    conn = sqlite3.connect('marketplace.db')
    c = conn.cursor()
    c.execute("SELECT id, name, price, description, seller_id FROM products WHERE id=?", (product_id,))
    product = c.fetchone()
    conn.close()
    return product

def create_order(buyer_id, cart_items):
    """cart_items: list of (product_id, quantity, price_at_time)"""
    conn = sqlite3.connect('marketplace.db')
    c = conn.cursor()
    total = sum(qty * price for _, qty, price in cart_items)
    now = datetime.now().isoformat()
    c.execute("INSERT INTO orders (buyer_id, order_date, total) VALUES (?, ?, ?)", (buyer_id, now, total))
    order_id = c.lastrowid
    for product_id, qty, price in cart_items:
        c.execute("INSERT INTO order_items (order_id, product_id, quantity, price_at_time) VALUES (?, ?, ?, ?)",
                  (order_id, product_id, qty, price))
    conn.commit()
    conn.close()
    return order_id

# ============================
# تطبيق الواجهة الرئيسية
# ============================
class MarketplaceApp:
    def __init__(self, root):
        self.root = root
        self.root.title("سوق البيع والشراء - Marketplace")
        self.root.geometry("800x600")
        self.current_user = None  # (id, username, role)
        self.cart = {}  # product_id -> quantity

        # إطار الحاوية (container) لتبديل الصفحات
        self.container = tk.Frame(root)
        self.container.pack(fill="both", expand=True)

        # قاموس الصفحات
        self.frames = {}

        # إنشاء الصفحات
        for F in (LoginPage, RegisterPage, SellerDashboard, BuyerDashboard, CartPage):
            page_name = F.__name__
            frame = F(parent=self.container, controller=self)
            self.frames[page_name] = frame
            frame.grid(row=0, column=0, sticky="nsew")

        self.show_frame("LoginPage")

    def show_frame(self, page_name):
        """عرض الصفحة المطلوبة"""
        frame = self.frames[page_name]
        frame.tkraise()

    def login_user(self, username, password):
        """تسجيل الدخول والتحقق من البيانات"""
        user = get_user(username, password)
        if user:
            self.current_user = user  # (id, username, role)
            role = user[2]
            if role == "seller":
                self.show_frame("SellerDashboard")
                self.frames["SellerDashboard"].refresh_products()
            else:
                self.show_frame("BuyerDashboard")
                self.frames["BuyerDashboard"].refresh_products()
            return True
        else:
            return False

    def logout(self):
        """تسجيل الخروج"""
        self.current_user = None
        self.cart = {}
        self.show_frame("LoginPage")

