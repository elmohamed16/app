        # عرض المجموع
        self.label_total = tk.Label(self, text="المجموع الكلي: 0.00", font=("Arial", 16))
        self.label_total.pack(pady=10)

        # أزرار التحكم
        frame_actions = tk.Frame(self)
        frame_actions.pack(pady=10)

        btn_remove = tk.Button(frame_actions, text="إزالة المنتج المحدد", font=("Arial", 12), command=self.remove_selected)
        btn_remove.pack(side="left", padx=10)

        btn_confirm = tk.Button(frame_actions, text="تأكيد الشراء (الدفع عند الاستلام)", font=("Arial", 12), command=self.confirm_order)
        btn_confirm.pack(side="left", padx=10)

        btn_back = tk.Button(frame_actions, text="العودة للتصفح", font=("Arial", 12), command=lambda: contro
btn_back.pack(side="left", padx=10)

        btn_logout = tk.Button(frame_actions, text="تسجيل الخروج", font=("Arial", 12), command=self.controller.logout)
        btn_logout.pack(side="left", padx=10)

    def refresh_cart(self):
        """تحديث عرض السلة وحساب المجموع"""
        for item in self.tree.get_children():
            self.tree.delete(item)
        total = 0.0
        cart_items = []
        for prod_id, qty in self.controller.cart.items():
            product = get_product_by_id(prod_id)
            if product:
                name, price, desc, seller_id = product[1], product[2], product[3], product[4]
                subtotal = price * qty
                total += subtotal
                self.tree.insert("", "end", values=(prod_id, name, price, qty, f"{subtotal:.2f}"))
                cart_items.append((prod_id, qty, price))
        self.label_total.config(text=f"المجموع الكلي: {total:.2f}")
        # تخزين بيانات السلة للاستخدام في تأكيد الطلب
        self.cart_items = cart_items

    def remove_selected(self):
        """إزالة منتج من السلة (نقص الكمية أو حذفه)"""
        selected = self.tree.selection()
        if not selected:
            messagebox.showerror("خطأ", "يرجى اختيار منتج")
            return
        item = self.tree.item(selected[0])
        prod_id = item['values'][0]
        if prod_id in self.controller.cart:
            if self.controller.cart[prod_id] > 1:
                self.controller.cart[prod_id] -= 1
            else:
                del self.controller.cart[prod_id]
        self.refresh_cart()

    def confirm_order(self):
        """تأكيد الشراء وإنشاء الطلب في قاعدة البيانات"""
        if not self.controller.cart:
            messagebox.showerror("خطأ", "السلة فارغة")
            return
        if not self.controller.current_user:
            messagebox.showerror("خطأ", "يرجى تسجيل الدخول")
            return
        buyer_id = self.controller.current_user[0]
        # تحضير بيانات الطلب
        cart_items = []
        for prod_id, qty in self.controller.cart.items():
            product = get_product_by_id(prod_id)
            if product:
                price = product[2]
                cart_items.append((prod_id, qty, price))
        if not cart_items:
            return
        try:
            order_id = create_order(buyer_id, cart_items)
            # مسح السلة
            self.controller.cart = {}
            messagebox.showinfo("نجاح", f"تم تأكيد الطلب برقم {order_id}. سيتم الدفع عند الاستلام.")
            self.refresh_cart()
            self.controller.show_frame("BuyerDashboard")
            self.controller.frames["BuyerDashboard"].refresh_products()
        except Exception as e:
            messagebox.showerror("خطأ", f"حدث خطأ أثناء إنشاء الطلب: {e}")

